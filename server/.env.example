NODE_ENV=production
PORT=3001
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/badminton-booking?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=1d
JWT_COOKIE_EXPIRES_IN=30
MAX_ACTIVE_TOKENS_PER_USER=5
CORS_ORIGIN=https://your-frontend-domain.vercel.app
SERVER_URL=https://your-render-service.onrender.com
ADMIN_INVITE_CODE=replace_with_admin_only_invite_code
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10
SIGNUP_RATE_LIMIT_WINDOW_MS=3600000
SIGNUP_RATE_LIMIT_MAX=5
OTP_RATE_LIMIT_WINDOW_MS=600000
OTP_RATE_LIMIT_MAX=5
OTP_RESEND_RATE_LIMIT_WINDOW_MS=600000
OTP_RESEND_RATE_LIMIT_MAX=3
# In-memory rate limiting is only safe for a single server instance.
# Use a shared store such as Redis before scaling horizontally.
# RATE_LIMIT_STORE=redis
# Nodemailer SMTP config. For Render, prefer an SMTP relay provider such as Brevo,
# SendGrid, Mailgun, or SMTP2GO. Gmail SMTP can timeout on hosted environments.
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_REQUIRE_TLS=true
EMAIL_CONNECTION_TIMEOUT_MS=10000
EMAIL_GREETING_TIMEOUT_MS=10000
EMAIL_SOCKET_TIMEOUT_MS=20000
EMAIL_ADDRESS_FAMILY=4
EMAIL_RESOLVE_IPV4=false
EMAIL_DEBUG=false
EMAIL_USER=your_smtp_username
EMAIL_PASS=your_smtp_password
EMAIL_FROM=Badminton Booking <your_verified_sender@example.com>

# Local Gmail alternative:
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=465
# EMAIL_SECURE=true
# EMAIL_REQUIRE_TLS=false
# EMAIL_RESOLVE_IPV4=true
# EMAIL_ADDRESS_FAMILY=4
# EMAIL_USER=your_gmail_address@gmail.com
# EMAIL_PASS=your_gmail_app_password
# EMAIL_FROM=Badminton Booking <your_gmail_address@gmail.com>
